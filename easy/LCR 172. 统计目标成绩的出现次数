某班级考试成绩按非严格递增顺序记录于整数数组 scores，请返回目标成绩 target 的出现次数。

class Solution {
    public int countTarget(int[] scores, int target) {
        int firstIndex = findBeginPosition(scores, target);
        int lastIndex = findEndPosition(scores, target);
        return firstIndex == -1 ? 0 : lastIndex - firstIndex + 1;
    }

    private int findBeginPosition(int[] scores, int target) {
        int left = 0, right = scores.length - 1;
        while (left <= right) {
            int mid = left + (right - left) / 2;
            if (scores[mid] == target) {
                if (mid == 0 || scores[mid - 1] < target) {
                    return mid;
                }
                right = mid - 1;
            } else if (scores[mid] < target) {
                left = mid + 1;
            } else {
                right = mid - 1;
            }
        }
        return -1;
    }

    private int findEndPosition(int[] scores, int target) {
        int left = 0, right = scores.length - 1;
        while (left <= right) {
            int mid = left + (right - left) / 2;
            if (scores[mid] == target) {
                if (mid == scores.length - 1 || scores[mid + 1] > target) {
                    return mid;
                }
                left = mid + 1;
            } else if (scores[mid] < target) {
                left = mid + 1;
            } else {
                right = mid - 1;
            }
        }
        return -1;
    }
}